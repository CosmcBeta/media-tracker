  "query": "SELECT\n        i.id AS \"id!: Uuid\",\n        i.media_type AS \"media_type: MediaType\",\n        i.title,\n        i.external_id,\n        i.metadata,\n        i.created_at as \"created_at: DateTime<Utc>\",\n        i.updated_at as \"updated_at: DateTime<Utc>\"\n        FROM items i\n        INNER JOIN list_items li ON i.id = li.item_id\n        WHERE li.list_id = $1",
